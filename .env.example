# LiveKit connection
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Laravel integration
LARAVEL_BASE_URL=http://localhost:8000
LARAVEL_ENDPOINT=${LARAVEL_BASE_URL}/api/frame-results
PIPELINE_INTERNAL_BASE_URL=${LARAVEL_BASE_URL}/internal/pipeline

# Must match Laravel's PIPELINE_SECRET exactly
PIPELINE_SHARED_SECRET=replace-with-same-secret-as-laravel

# ArcFace matching behavior
FACE_MATCH_THRESHOLD=0.4
FACE_MATCH_STREAK_TARGET=3
FRAME_ANALYSIS_INTERVAL_SECONDS=1.0
VIDEO_STREAM_CAPACITY=1
FRAME_ANALYSIS_MAX_WORKERS=1
SAVED_FRAMES_DIR=saved_frames
DEEPFAKE_REPORTING_ROLE=both

# Deepfake detector backend selection
DEEPFAKE_MODEL_BACKEND=deepfakebench_effnb4
DEEPFAKE_FALLBACK_BACKEND=deepfakebench_effnb4
DEEPFAKE_BACKEND_STRICT=false
DEEPFAKE_AUTO_CORRECT_FAKE_CLASS_INDEX=false

# Shared deepfake inference settings
DEEPFAKE_WEIGHTS_DIR=models/deepfakebench
DEEPFAKE_MODEL_PATH=${DEEPFAKE_WEIGHTS_DIR}/effnb4_best.pth
DEEPFAKE_MODEL_URL=https://github.com/SCLBD/DeepfakeBench/releases/download/v1.0.1/effnb4_best.pth
DEEPFAKE_BACKBONE_PATH=${DEEPFAKE_WEIGHTS_DIR}/efficientnet-b4-6ed6700e.pth
DEEPFAKE_BACKBONE_URL=https://github.com/lukemelas/EfficientNet-PyTorch/releases/download/1.0/efficientnet-b4-6ed6700e.pth
DEEPFAKE_AUTO_DOWNLOAD=true
DEEPFAKE_MODEL_VERSION=deepfakebench_effnb4
DEEPFAKE_INPUT_SIZE=256
DEEPFAKE_FAKE_THRESHOLD=0.5
DEEPFAKE_INCONCLUSIVE_MARGIN=0.05
DEEPFAKE_FAKE_CLASS_INDEX=1
DEEPFAKE_USE_FACE_CROPS=true
DEEPFAKE_FULL_FRAME_FALLBACK=false
DEEPFAKE_FACE_MARGIN_RATIO=0.25
DEEPFAKE_MIN_FACE_SIZE=48
DEEPFAKE_SCORE_AGGREGATION=max

# Optional UCF backend settings (used when DEEPFAKE_MODEL_BACKEND=deepfakebench_ucf)
DEEPFAKE_UCF_MODEL_PATH=${DEEPFAKE_WEIGHTS_DIR}/ucf_best.pth
DEEPFAKE_UCF_MODEL_URL=https://github.com/SCLBD/DeepfakeBench/releases/download/v1.0.1/ucf_best.pth
DEEPFAKE_UCF_BACKBONE_PATH=${DEEPFAKE_BACKBONE_PATH}
DEEPFAKE_UCF_BACKBONE_URL=${DEEPFAKE_BACKBONE_URL}
DEEPFAKE_UCF_MODEL_VERSION=deepfakebench_ucf
DEEPFAKE_UCF_INPUT_SIZE=256
DEEPFAKE_UCF_ENCODER_FEAT_DIM=512
DEEPFAKE_UCF_FAKE_CLASS_INDEX=
DEEPFAKE_UCF_FAKE_THRESHOLD=

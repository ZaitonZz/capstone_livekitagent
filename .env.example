# LiveKit connection
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Laravel integration
LARAVEL_BASE_URL=http://localhost:8000
LARAVEL_ENDPOINT=${LARAVEL_BASE_URL}/api/frame-results
PIPELINE_INTERNAL_BASE_URL=${LARAVEL_BASE_URL}/internal/pipeline

# Must match Laravel's PIPELINE_SECRET exactly
PIPELINE_SHARED_SECRET=replace-with-same-secret-as-laravel

# ArcFace matching behavior
FACE_MATCH_THRESHOLD=0.4
FACE_MATCH_STREAK_TARGET=3
FRAME_ANALYSIS_INTERVAL_SECONDS=1.0
VIDEO_STREAM_CAPACITY=1
FRAME_ANALYSIS_MAX_WORKERS=1
SAVED_FRAMES_DIR=saved_frames
DEEPFAKE_REPORTING_ROLE=both

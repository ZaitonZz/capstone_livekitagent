LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=key
LIVEKIT_API_SECRET=secret

# Laravel integration
LARAVEL_BASE_URL=https://ampingtk.me
LARAVEL_ENDPOINT=${LARAVEL_BASE_URL}/api/frame-results
PIPELINE_INTERNAL_BASE_URL=${LARAVEL_BASE_URL}/internal/pipeline

PIPELINE_SHARED_SECRET=dev-pipeline-secret

# ArcFace matching behavior
FACE_MATCH_THRESHOLD=0.4
FACE_MATCH_STREAK_TARGET=3
FRAME_ANALYSIS_INTERVAL_SECONDS=1.0
SAVED_FRAMES_DIR=saved_frames
DEEPFAKE_REPORTING_ROLE=both
DEEPFAKE_FAKE_CLASS_INDEX=0
DEEPFAKE_USE_FACE_CROPS=true
DEEPFAKE_FULL_FRAME_FALLBACK=false
DEEPFAKE_SCORE_AGGREGATION=max
PYTORCH_DISABLE_NNPACK=1
TORCH_CPP_LOG_LEVEL=ERROR